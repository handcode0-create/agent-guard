{
  "manifest_version": 3,
  "name": "Agent Guard Bridge",
  "version": "1.0.0",
  "description": "Envoie le code généré dans Google AI Studio vers agent-guard (staging local), jamais directement dans le projet.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://aistudio.google.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://aistudio.google.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Agent Guard Bridge"
  },
  "icons": {
    "48": "icon.png"
  }
}
